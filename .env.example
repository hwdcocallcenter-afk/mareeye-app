# Koobiye faylkan oo u magac beddel ".env" (localka), ama geli Render "Environment"
# Furahaaga API-ga ka soo qaado: https://console.anthropic.com  ->  API Keys

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model-ka (ikhtiyaari). Tan hoose waa mid tayo sare leh.
# Si aad qiimaha u yarayso, isticmaal: claude-haiku-4-5-20251001
MODEL=claude-sonnet-5

# --- Cusub: Database + Authentication (Phase 1 backend upgrade) ---

# Xidhiidhka MongoDB Atlas (ama instance kale oo Mongo ah).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mareeye

# Sirta lagu saxiixo JWT access tokens-ka. Samee mid dherer badan oo random ah,
# tusaale: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string

# Ikhtiyaari — waxay lahaadaan qiimayaal caadi ah haddii aan la dejin:
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL_DAYS=30

# Ikhtiyaari — "production" ayaa qariya faahfaahinta khaladaadka + dib-u-dejinta
# password-ka (forgot-password) token-ka dev-ga kaliya lagu muujiyo marka aanay
# lahayn "production".
NODE_ENV=production
